JWT_SECRET=replace_with_a_long_random_secret
MEDIA_ROOT=/absolute/path/to/your/media/folder
PORT=3001
# Optional: allow new sign-ups after the first user exists (default: first user only)
ALLOW_REGISTRATION=false
# Optional: comma-separated allowed browser origins (default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173
